@model QuizManagement.ViewModels.Admin.UserListViewModel
@using BusinessObjects
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Quản lý người dùng</h1>
        <p style="color:var(--text-muted);margin:0;">Hiển thị @Model.Users.Count người dùng</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">← Dashboard</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-sm-6 col-md-5">
        <input type="text" name="search" class="form-control" placeholder="Tìm theo tên hoặc email..."
               value="@Model.SearchQuery" />
    </div>
    <div class="col-sm-4 col-md-3">
        <select name="role" class="form-select">
            <option value="">-- Tất cả vai trò --</option>
            <option value="@AppRoles.Admin" selected="@(Model.RoleFilter == AppRoles.Admin)">Admin</option>
            <option value="@AppRoles.Mentor" selected="@(Model.RoleFilter == AppRoles.Mentor)">Mentor</option>
            <option value="@AppRoles.User" selected="@(Model.RoleFilter == AppRoles.User)">User</option>
        </select>
    </div>
    <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
        <a asp-action="Users" class="btn btn-outline-secondary">Xóa lọc</a>
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Người dùng</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                                    {
                                        <img src="@user.AvatarUrl" alt="avatar" class="rounded-circle"
                                             style="width:32px;height:32px;object-fit:cover;"
                                             onerror="this.replaceWith(this.nextElementSibling)" />
                                    }
                                    <span class="u-avatar">
                                        @(user.Username?.Length > 0 ? user.Username[0].ToString().ToUpper() : "U")
                                    </span>
                                    <span class="fw-semibold">@user.Username</span>
                                </div>
                            </td>
                            <td style="color:var(--text-muted);">@user.Email</td>
                            <td>
                                @{
                                    var roleBadge = user.Role switch
                                    {
                                        AppRoles.Admin => "bg-danger",
                                        AppRoles.Mentor => "bg-warning text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @roleBadge">@(user.Role ?? "User")</span>
                            </td>
                            <td>
                                @if (user.IsDisabled)
                                {
                                    <span class="badge" style="background:rgba(248,113,113,.15);color:var(--danger);border:1px solid rgba(248,113,113,.25);">Bị khóa</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:rgba(52,211,153,.15);color:var(--success);border:1px solid rgba(52,211,153,.25);">Hoạt động</span>
                                }
                            </td>
                            <td style="color:var(--text-muted);font-size:.8rem;">@VietnamTime.FromUtc(user.CreatedAt).ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-action="UserDetail" asp-route-id="@user.Id"
                                   class="btn btn-sm btn-outline-secondary">Chi tiết</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color:var(--text-muted);">
                                Không tìm thấy người dùng.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
