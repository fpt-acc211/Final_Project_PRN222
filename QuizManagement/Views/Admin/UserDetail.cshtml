@model QuizManagement.ViewModels.Admin.UserDetailViewModel
@using BusinessObjects
@{
    ViewData["Title"] = "Chi tiết người dùng";
    var user = Model.User;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Chi tiết người dùng</h1>
    <a asp-action="Users" class="btn btn-outline-secondary">← Danh sách</a>
</div>

@if (TempData["SuccessMessage"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                {
                    <img src="@user.AvatarUrl" alt="avatar"
                         class="rounded-circle mb-3"
                         style="width:80px;height:80px;object-fit:cover;"
                         onerror="this.src='/img/default-avatar.png'" />
                }
                else
                {
                    <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center mb-3"
                         style="width:80px;height:80px;font-size:2rem;color:white;">
                        @user.Username[0].ToString().ToUpper()
                    </div>
                }
                <h5 class="mb-1">@user.Username</h5>
                <p class="text-muted small mb-2">@user.Email</p>
                @{
                    var badgeClass = user.Role switch
                    {
                        AppRoles.Admin => "bg-danger",
                        AppRoles.Mentor => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                }
                <span class="badge @badgeClass mb-2">@(user.Role ?? AppRoles.User)</span>
                <br />
                @if (user.IsDisabled)
                {
                    <span class="badge bg-dark">Bị khóa</span>
                }
                else
                {
                    <span class="badge bg-success">Hoạt động</span>
                }
                <div class="text-muted small mt-2">Tham gia: @user.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header fw-semibold">Hoạt động</div>
            <div class="card-body">
                <div class="row text-center g-3">
                    <div class="col-6 col-sm-3">
                        <div class="fs-4 fw-bold text-success">@Model.SubjectCount</div>
                        <div class="small text-muted">Môn học</div>
                    </div>
                    <div class="col-6 col-sm-3">
                        <div class="fs-4 fw-bold text-info">@Model.DeckCount</div>
                        <div class="small text-muted">Bộ đề</div>
                    </div>
                    <div class="col-6 col-sm-3">
                        <div class="fs-4 fw-bold text-warning">@Model.QuestionCount</div>
                        <div class="small text-muted">Câu hỏi</div>
                    </div>
                    <div class="col-6 col-sm-3">
                        <div class="fs-4 fw-bold text-primary">@Model.TestHistoryCount</div>
                        <div class="small text-muted">Lần làm bài</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header fw-semibold">Thao tác</div>
            <div class="card-body d-flex flex-wrap gap-2">
                <a asp-action="ChangeRole" asp-route-id="@user.Id"
                   class="btn btn-outline-primary">Đổi vai trò</a>

                <form asp-action="ToggleDisabled" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@user.Id" />
                    @if (user.IsDisabled)
                    {
                        <button type="submit" class="btn btn-outline-success"
                                onclick="return confirm('Kích hoạt lại tài khoản @user.Username?')">
                            Kích hoạt
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-outline-danger"
                                onclick="return confirm('Vô hiệu hóa tài khoản @user.Username?')">
                            Vô hiệu hóa
                        </button>
                    }
                </form>
            </div>
        </div>
    </div>
</div>
