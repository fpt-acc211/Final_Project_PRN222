@model QuizManagement.ViewModels.Admin.ChangeRoleViewModel
@using BusinessObjects
@{
    ViewData["Title"] = "Đổi vai trò";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-semibold">Đổi vai trò — @Model.CurrentUsername</div>
            <div class="card-body">
                <form asp-action="ChangeRole" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="CurrentUsername" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn vai trò mới</label>
                        <div class="vstack gap-2">
                            @foreach (var role in AppRoles.All)
                            {
                                <div class="form-check border rounded p-3 @(Model.NewRole == role ? "border-primary bg-light" : "")">
                                    <input class="form-check-input" type="radio"
                                           asp-for="NewRole" value="@role"
                                           id="role_@role" />
                                    <label class="form-check-label w-100" for="role_@role">
                                        <strong>@role</strong>
                                        <span class="text-muted ms-2 small">
                                            @(role == AppRoles.Admin ? "— Toàn quyền hệ thống" :
                                              role == AppRoles.Mentor ? "— Tạo và quản lý nội dung" :
                                              "— Làm quiz và xem lịch sử")
                                        </span>
                                    </label>
                                </div>
                            }
                        </div>
                        <span asp-validation-for="NewRole" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-warning small">
                        Thay đổi vai trò sẽ buộc người dùng phải đăng nhập lại để vai trò mới có hiệu lực.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                        <a asp-action="UserDetail" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
