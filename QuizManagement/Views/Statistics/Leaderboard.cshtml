@model LeaderboardViewModel
@{
    ViewData["Title"] = "Bảng xếp hạng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Bảng xếp hạng</h1>
        <p style="color:var(--text-muted);margin:0;">
            <a asp-controller="Subjects" asp-action="Index" style="color:var(--accent);">Môn học</a>
            <span style="color:var(--text-dim);margin:0 .4rem;">›</span>
            @Model.SubjectName
            <span style="color:var(--text-dim);margin:0 .4rem;">›</span>
            <a asp-controller="Decks" asp-action="Index"
               asp-route-subjectId="@ViewBag.SubjectId" style="color:var(--accent);">@Model.DeckName</a>
        </p>
    </div>
    <a asp-controller="Quiz" asp-action="Config" asp-route-deckId="@Model.DeckId"
       class="btn btn-primary">Làm bài</a>
</div>

@if (!Model.Entries.Any())
{
    <div class="alert alert-info">Chưa có ai làm bài này. Hãy là người đầu tiên!</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4" style="width:4rem;">Hạng</th>
                            <th>Người dùng</th>
                            <th class="text-center">Điểm cao nhất</th>
                            <th class="text-center">Số lần</th>
                            <th class="text-center">Lần cuối</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.Entries)
                        {
                            var medalClass = entry.Rank switch
                            {
                                1 => "text-warning fw-bold",
                                2 => "text-secondary fw-semibold",
                                3 => "text-danger fw-semibold",
                                _ => ""
                            };
                            var medal = entry.Rank switch
                            {
                                1 => "🥇",
                                2 => "🥈",
                                3 => "🥉",
                                _ => entry.Rank.ToString()
                            };
                            var scoreClass = entry.BestPercentage >= 80 ? "text-success fw-semibold"
                                           : entry.BestPercentage >= 50 ? ""
                                           : "text-danger";
                            <tr>
                                <td class="ps-4 @medalClass" style="font-size:1.1rem;">@medal</td>
                                <td>@entry.Username</td>
                                <td class="text-center @scoreClass">@entry.BestPercentage.ToString("0.#")%</td>
                                <td class="text-center" style="color:var(--text-muted);">@entry.AttemptCount lần</td>
                                <td class="text-center" style="color:var(--text-muted);font-size:.85rem;">
                                    @entry.LastAttemptAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
