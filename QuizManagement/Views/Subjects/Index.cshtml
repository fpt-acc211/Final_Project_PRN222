@model IEnumerable<BusinessObjects.Subject>

@{
    ViewData["Title"] = "Môn học";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Môn học</h1>
        <p class="text-muted mb-0">Quản lý các nhóm kiến thức và bộ đề của bạn.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Tạo môn học</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có môn học nào. Hãy tạo môn học đầu tiên.</div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Tên môn học</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var subject in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="Decks" asp-action="Index" asp-route-subjectId="@subject.Id" class="fw-semibold text-decoration-none">
                                @subject.Name
                            </a>
                        </td>
                        <td>@subject.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end">
                            <a asp-controller="Decks" asp-action="Index" asp-route-subjectId="@subject.Id" class="btn btn-sm btn-outline-primary">Bộ đề</a>
                            <a asp-action="Edit" asp-route-id="@subject.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@subject.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa môn học này và ẩn các bộ đề liên quan?');">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
