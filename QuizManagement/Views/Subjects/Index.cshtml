@model IEnumerable<BusinessObjects.Subject>

@{
    ViewData["Title"] = "Môn học";
    var currentUserId = (string)ViewBag.CurrentUserId;
    var canCreate = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.Mentor);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Môn học</h1>
        <p style="color:var(--text-muted);margin:0;">Quản lý các nhóm kiến thức và bộ đề của bạn.</p>
    </div>
    @if (canCreate)
    {
        <a asp-action="Create" class="btn btn-primary">+ Tạo môn học</a>
    }
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có môn học nào.</div>
}
else
{
    <div class="item-grid">
        @foreach (var subject in Model)
        {
            var canManage = User.IsInRole(AppRoles.Admin) ||
                (User.IsInRole(AppRoles.Mentor) && subject.UserId == currentUserId);
            <div class="item-card" style="animation: fadeUp .35s ease both;">
                <div class="item-card__body">
                    <a asp-controller="Decks" asp-action="Index" asp-route-subjectId="@subject.Id"
                       class="item-card__title">@subject.Name</a>
                    <p class="item-card__meta">Tạo lúc @subject.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</p>
                </div>
                <div class="item-card__actions">
                    <a asp-controller="Decks" asp-action="Index" asp-route-subjectId="@subject.Id"
                       class="btn btn-sm btn-primary">Bộ đề</a>
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@subject.Id"
                           class="btn btn-sm btn-outline-secondary">Sửa</a>
                        <form asp-action="Delete" asp-route-id="@subject.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Xóa môn học này và ẩn các bộ đề liên quan?');">Xóa</button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}
