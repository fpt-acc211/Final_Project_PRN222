@model QuizManagement.ViewModels.Account.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-container">

        <div class="auth-brand">
            <div class="auth-brand-logo">Q</div>
            <h1>Tạo tài khoản</h1>
            <p>Bắt đầu hành trình học tập của bạn</p>
        </div>

        <div class="auth-card">
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Tên người dùng</label>
                    <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="Username" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" autocomplete="email" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                    <input asp-for="Password" class="form-control" type="password" autocomplete="new-password" placeholder="••••••••" />
                    <div class="form-text">Dùng passphrase từ 15 đến 100 ký tự; không bắt buộc kiểu ký tự.</div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100" style="padding:.65rem;">
                    Tạo tài khoản
                </button>
            </form>
        </div>

        <p class="auth-footer">
            Đã có tài khoản?
            <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
