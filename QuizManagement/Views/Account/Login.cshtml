@model QuizManagement.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-container">

        <div class="auth-brand">
            <div class="auth-brand-logo">Q</div>
            <h1>Chào mừng trở lại</h1>
            <p>Đăng nhập để tiếp tục học tập</p>
        </div>

        <div class="auth-card">
            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success mb-4">@successMessage</div>
            }

            <form asp-action="Login" method="post">
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" autocomplete="email" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                    <input asp-for="Password" class="form-control" type="password" autocomplete="current-password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn btn-primary w-100" style="padding:.65rem;">
                    Đăng nhập
                </button>
            </form>
        </div>

        <p class="auth-footer">
            Chưa có tài khoản?
            <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
