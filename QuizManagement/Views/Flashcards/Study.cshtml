@model FlashcardStudyViewModel
@using System.Text.Encodings.Web
@using System.Text.Json
@{
    ViewData["Title"] = "Flashcard";
    var json = JsonSerializer.Serialize(Model.Cards, new JsonSerializerOptions { Encoder = JavaScriptEncoder.Default });
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Flashcard</h1>
        <p class="text-muted mb-0">@Model.SubjectName / @Model.DeckName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Quiz" asp-action="Config" asp-route-deckId="@Model.DeckId" class="btn btn-outline-success">Làm quiz</a>
        <a asp-controller="Questions" asp-action="Index" asp-route-deckId="@Model.DeckId" class="btn btn-outline-secondary">Câu hỏi</a>
    </div>
</div>

@if (!Model.Cards.Any())
{
    <div class="alert alert-info">Bộ đề này chưa có câu hỏi để học flashcard.</div>
}
else
{
    <div id="flashcardApp" class="flashcard-study mx-auto">
        <div class="flashcard-toolbar">
            <button type="button" id="prevCardButton" class="btn btn-outline-secondary">Trước</button>
            <div class="text-center">
                <div id="cardCounter" class="fw-semibold"></div>
                <div id="studyCounter" class="small text-muted"></div>
            </div>
            <button type="button" id="nextCardButton" class="btn btn-outline-secondary">Tiếp</button>
        </div>

        <div class="fc-scene">
            <div id="flashcardInner" class="fc-card">
                <!-- FRONT: Question + Answer Options -->
                <div class="fc-face fc-face--front">
                    <div class="flashcard-side-label" id="cardTypeFront"></div>
                    <div class="flashcard-question" id="questionTextFront"></div>
                    <div class="fc-options" id="optionsPanel"></div>
                    <div class="fc-hint">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41zm-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9z"/><path fill-rule="evenodd" d="M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5.002 5.002 0 0 0 8 3zM3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9H3.1z"/></svg>
                        Nhấn để lật thẻ
                    </div>
                </div>
                <!-- BACK: Correct Answer + Explanation -->
                <div class="fc-face fc-face--back">
                    <div class="flashcard-side-label">Đáp án</div>
                    <div class="fc-back-content">
                        <div id="backAnswerList" class="fc-back-answers"></div>
                        <div id="backExplanation" class="fc-back-explanation"></div>
                    </div>
                    <div class="fc-hint">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41zm-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9z"/><path fill-rule="evenodd" d="M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5.002 5.002 0 0 0 8 3zM3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9H3.1z"/></svg>
                        Nhấn để lật lại
                    </div>
                </div>
            </div>
        </div>

        <div class="flashcard-actions">
            <button type="button" id="againButton" class="btn btn-outline-danger d-none">
                <span class="fc-key-badge">R</span> Cần học lại
            </button>
            <button type="button" id="knownButton" class="btn btn-outline-success d-none">
                <span class="fc-key-badge">Enter</span> Đã nhớ
            </button>
            <button type="button" id="shuffleButton" class="btn btn-outline-secondary">Trộn thẻ</button>
        </div>

        <div class="fc-shortcut-guide">
            <div class="fc-shortcut-title">Phím tắt</div>
            <div class="fc-shortcut-grid">
                <div class="fc-shortcut-item"><kbd>Space</kbd><span>Lật thẻ</span></div>
                <div class="fc-shortcut-item"><kbd>←</kbd><span>Thẻ trước</span></div>
                <div class="fc-shortcut-item"><kbd>→</kbd><span>Thẻ tiếp</span></div>
                <div class="fc-shortcut-item"><kbd>↑</kbd> <kbd>↓</kbd><span>Lật thẻ</span></div>
                <div class="fc-shortcut-item"><kbd>Enter</kbd><span>Đã nhớ</span></div>
                <div class="fc-shortcut-item"><kbd>R</kbd><span>Cần học lại</span></div>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const cards = @Html.Raw(json);
            let currentIndex = 0;
            let flipped = false;

            // Per-card status: 'unseen' | 'known' | 'again'
            const cardStatus = new Map();

            const cardInner = document.getElementById('flashcardInner');
            const questionTextFront = document.getElementById('questionTextFront');
            const cardTypeFront = document.getElementById('cardTypeFront');
            const optionsPanel = document.getElementById('optionsPanel');
            const backAnswerList = document.getElementById('backAnswerList');
            const backExplanation = document.getElementById('backExplanation');
            const againButton = document.getElementById('againButton');
            const knownButton = document.getElementById('knownButton');
            const shuffleButton = document.getElementById('shuffleButton');
            const prevCardButton = document.getElementById('prevCardButton');
            const nextCardButton = document.getElementById('nextCardButton');
            const cardCounter = document.getElementById('cardCounter');
            const studyCounter = document.getElementById('studyCounter');

            const labels = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H'];

            function getCounts() {
                let known = 0, again = 0;
                for (const status of cardStatus.values()) {
                    if (status === 'known') known++;
                    else if (status === 'again') again++;
                }
                return { known, again };
            }

            function renderCard() {
                const card = cards[currentIndex];
                flipped = false;
                cardInner.classList.remove('fc-card--flipped');

                // Front side
                questionTextFront.textContent = card.Content || '';
                cardTypeFront.textContent = card.QuestionType === 1 ? 'Một đáp án đúng' : 'Nhiều đáp án đúng';

                // Options on front
                optionsPanel.innerHTML = '';
                for (let i = 0; i < (card.AllAnswers || []).length; i++) {
                    const opt = card.AllAnswers[i];
                    const el = document.createElement('div');
                    el.className = 'fc-option';
                    el.innerHTML = `<span class="fc-option-label">${labels[i] || (i + 1)}</span><span class="fc-option-text">${escapeHtml(opt.Content)}</span>`;
                    optionsPanel.appendChild(el);
                }

                // Back side
                backAnswerList.innerHTML = '';
                for (let i = 0; i < (card.AllAnswers || []).length; i++) {
                    const opt = card.AllAnswers[i];
                    const el = document.createElement('div');
                    el.className = 'fc-back-option' + (opt.IsCorrect ? ' fc-back-option--correct' : ' fc-back-option--wrong');
                    el.innerHTML = `<span class="fc-option-label">${labels[i] || (i + 1)}</span><span class="fc-option-text">${escapeHtml(opt.Content)}</span>${opt.IsCorrect ? '<svg class="fc-check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>' : ''}`;
                    backAnswerList.appendChild(el);
                }

                if (card.Explanation) {
                    backExplanation.innerHTML = `<div class="fc-explanation-title">Giải thích</div><div class="fc-explanation-body">${escapeHtml(card.Explanation)}</div>`;
                    backExplanation.classList.remove('d-none');
                } else {
                    backExplanation.innerHTML = '';
                    backExplanation.classList.add('d-none');
                }

                // Buttons
                againButton.classList.add('d-none');
                knownButton.classList.add('d-none');
                updateCounters();
            }

            function updateCounters() {
                const { known, again } = getCounts();
                cardCounter.textContent = `Thẻ ${currentIndex + 1}/${cards.length}`;
                studyCounter.textContent = `${known} đã nhớ · ${again} cần học lại`;
            }

            function flipCard() {
                flipped = !flipped;
                cardInner.classList.toggle('fc-card--flipped', flipped);

                if (flipped) {
                    againButton.classList.remove('d-none');
                    knownButton.classList.remove('d-none');
                } else {
                    againButton.classList.add('d-none');
                    knownButton.classList.add('d-none');
                }
            }

            function move(delta) {
                currentIndex = (currentIndex + delta + cards.length) % cards.length;
                renderCard();
            }

            function markAndMove(isKnown) {
                const cardId = cards[currentIndex].QuestionId;
                cardStatus.set(cardId, isKnown ? 'known' : 'again');
                move(1);
            }

            function shuffleCards() {
                for (let i = cards.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [cards[i], cards[j]] = [cards[j], cards[i]];
                }
                currentIndex = 0;
                renderCard();
            }

            function escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // Event listeners
            cardInner.addEventListener('click', flipCard);
            document.addEventListener('keydown', event => {
                if (event.key === ' ') {
                    event.preventDefault();
                    flipCard();
                }
                if (event.key === 'ArrowRight') {
                    move(1);
                }
                if (event.key === 'ArrowLeft') {
                    move(-1);
                }
                if (event.key === 'ArrowUp' || event.key === 'ArrowDown') {
                    event.preventDefault();
                    flipCard();
                }
                if (event.key === 'Enter') {
                    event.preventDefault();
                    if (flipped) {
                        markAndMove(true);
                    } else {
                        flipCard();
                    }
                }
                if (flipped && (event.key === 'r' || event.key === 'R')) {
                    markAndMove(false);
                }
            });
            prevCardButton.addEventListener('click', () => move(-1));
            nextCardButton.addEventListener('click', () => move(1));
            againButton.addEventListener('click', () => markAndMove(false));
            knownButton.addEventListener('click', () => markAndMove(true));
            shuffleButton.addEventListener('click', shuffleCards);

            renderCard();
        })();
    </script>
}