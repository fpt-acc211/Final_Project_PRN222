@model QuizManagement.ViewModels.Profile.EditProfileViewModel
@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Chỉnh sửa hồ sơ</h1>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Hủy</a>
        </div>

        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold">Tên người dùng</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AvatarUrl" class="form-label fw-semibold">URL Avatar <span class="text-muted fw-normal">(tùy chọn)</span></label>
                        <input asp-for="AvatarUrl" class="form-control" placeholder="https://example.com/avatar.jpg" />
                        <div class="form-text">Nhập URL hình ảnh công khai để dùng làm avatar.</div>
                        <span asp-validation-for="AvatarUrl" class="text-danger small"></span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
                    {
                        <div class="mb-3">
                            <label class="form-label text-muted small">Xem trước avatar</label>
                            <br />
                            <img src="@Model.AvatarUrl" alt="preview"
                                 class="rounded-circle"
                                 style="width:64px;height:64px;object-fit:cover;"
                                 onerror="this.style.display='none'" />
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
