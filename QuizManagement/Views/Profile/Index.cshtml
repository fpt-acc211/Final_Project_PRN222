@model QuizManagement.ViewModels.Profile.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Hồ sơ cá nhân</h1>
            <a asp-action="Edit" class="btn btn-outline-primary btn-sm">Chỉnh sửa</a>
        </div>

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @success
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card mb-3">
            <div class="card-body d-flex align-items-center gap-4">
                @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="avatar"
                         class="rounded-circle flex-shrink-0"
                         style="width:72px;height:72px;object-fit:cover;"
                         onerror="this.style.display='none'" />
                }
                else
                {
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width:72px;height:72px;font-size:1.8rem;font-weight:700;background:var(--accent-light);color:var(--accent);border:2px solid rgba(124,109,248,0.3);">
                        @Model.Username[0].ToString().ToUpper()
                    </div>
                }
                <div>
                    <h4 class="mb-1">@Model.Username</h4>
                    <div class="text-muted">@Model.Email</div>
                    <span class="badge bg-secondary mt-1">@(Model.Role ?? "User")</span>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Tên người dùng</dt>
                    <dd class="col-sm-8">@Model.Username</dd>
                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4 text-muted">Vai trò</dt>
                    <dd class="col-sm-8">@(Model.Role ?? "User")</dd>
                    <dt class="col-sm-4 text-muted">Tham gia</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        <a asp-action="ChangePassword" class="btn btn-outline-warning">Đổi mật khẩu</a>
    </div>
</div>
