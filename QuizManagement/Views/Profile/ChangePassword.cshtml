@model QuizManagement.ViewModels.Profile.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Đổi mật khẩu</h1>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Hủy</a>
        </div>

        <div class="card">
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-semibold">Mật khẩu hiện tại</label>
                        <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold">Mật khẩu mới</label>
                        <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-info small">
                        Sau khi đổi mật khẩu, bạn sẽ được đăng xuất và yêu cầu đăng nhập lại.
                    </div>

                    <button type="submit" class="btn btn-warning w-100">Xác nhận đổi mật khẩu</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
