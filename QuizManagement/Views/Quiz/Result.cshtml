@model QuizResultViewModel
@{
    ViewData["Title"] = "Kết quả bài quiz";
    var passed = Model.Percentage >= 50;
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="h3 mb-1">Kết quả bài quiz</h1>
        <p style="color:var(--text-muted);margin:0;">@Model.SubjectName / @Model.DeckName</p>
    </div>
    <a asp-controller="History" asp-action="Index" class="btn btn-outline-secondary">Lịch sử</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="result-summary mb-5">
    <div class="score-ring @(passed ? "pass" : "fail")">
        <span class="sv">@Model.Percentage.ToString("0.#")%</span>
        <span class="sl">@Model.Score.ToString("0.##")/10</span>
    </div>
    <div class="result-meta">
        <div class="stat-card stat-card--purple">
            <div class="stat-card__label">Số câu đúng</div>
            <div class="stat-card__value">@Model.CorrectCount/@Model.TotalCount</div>
        </div>
        <div class="stat-card @(passed ? "stat-card--green" : "stat-card--red")">
            <div class="stat-card__label">Kết quả</div>
            <div class="stat-card__value" style="font-size:1.3rem;">@(passed ? "Đạt" : "Không đạt")</div>
        </div>
        <div class="stat-card stat-card--cyan">
            <div class="stat-card__label">Thời gian</div>
            <div class="stat-card__value" style="font-size:1rem;">@VietnamTime.FromUtc(Model.CreatedAt).ToString("dd/MM HH:mm")</div>
        </div>
    </div>
</div>

<h4 class="mb-3">Chi tiết câu hỏi</h4>

<div class="vstack gap-3">
    @for (int i = 0; i < Model.Questions.Count; i++)
    {
        var question = Model.Questions[i];
        <div class="result-card @(question.IsCorrect ? "result-card--correct" : "result-card--wrong")">
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge @(question.IsCorrect ? "bg-success" : "bg-danger")">
                    Câu @(i + 1) — @(question.IsCorrect ? "Đúng" : "Sai")
                </span>
                @if (question.QuestionType == 2)
                {
                    <span class="badge" style="background:var(--accent-light);color:var(--accent);font-size:.7rem;">Nhiều đáp án</span>
                }
            </div>

            <div class="fs-5 mb-3 markdown-content">@SafeMarkdown.ToHtml(question.Content)</div>

            <div class="vstack gap-2">
                @foreach (var answer in question.Answers)
                {
                    string ansClass;
                    if (answer.WasSelected && answer.IsCorrectAnswer)
                        ansClass = "result-answer correct-selected";
                    else if (answer.WasSelected && !answer.IsCorrectAnswer)
                        ansClass = "result-answer wrong-selected";
                    else if (!answer.WasSelected && answer.IsCorrectAnswer)
                        ansClass = "result-answer correct-missed";
                    else
                        ansClass = "result-answer";

                    <div class="@ansClass">
                        <span>@SafeMarkdown.ToInlineHtml(answer.Content)</span>
                        <div class="d-inline-flex gap-1 ms-2">
                            @if (answer.IsCorrectAnswer)
                            {
                                <span class="badge bg-success">Đáp án đúng</span>
                            }
                            @if (answer.WasSelected)
                            {
                                <span class="badge bg-primary">Đã chọn</span>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(question.Explanation))
            {
                <div class="alert alert-info mt-3 mb-0 markdown-content">
                    <strong>Giải thích:</strong>
                    @SafeMarkdown.ToHtml(question.Explanation)
                </div>
            }
            <div class="mt-3 d-flex justify-content-end">
                <a asp-controller="QuestionReports" asp-action="Create"
                   asp-route-questionId="@question.QuestionId"
                   asp-route-testHistoryId="@Model.TestHistoryId"
                   class="btn btn-sm btn-outline-secondary"
                   style="font-size:.8rem;opacity:.7;">
                    ⚑ Báo cáo câu hỏi
                </a>
            </div>
        </div>
    }
</div>
