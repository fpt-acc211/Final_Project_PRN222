@using BusinessObjects
<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b1120" />
    <title>@ViewData["Title"] - QuizManagement</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuizManagement.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    QuizMS
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Subjects" asp-action="Index">Môn học</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Statistics" asp-action="Index">Thống kê</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="History" asp-action="Index">Lịch sử</a>
                            </li>
                            @if (User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.Mentor))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Statistics" asp-action="MentorStats">Thống kê nội dung</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="QuestionReports" asp-action="Index">Báo cáo lỗi</a>
                                </li>
                            }
                            @if (User.IsInRole(AppRoles.Admin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-semibold" asp-controller="Admin" asp-action="Index">Quản trị</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#"
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="nav-avatar">
                                        @(User.Identity.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U")
                                    </span>
                                    <span class="d-none d-md-inline">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                            Hồ sơ
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Profile" asp-action="ChangePassword">
                                            Đổi mật khẩu
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline w-100">
                                            <button type="submit" class="dropdown-item" style="color:var(--danger)!important;">
                                                Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item ms-1">
                                <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register"
                                   style="padding:0.35rem 0.85rem;">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container page-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            <span>&copy; 2026 QuizManagement</span>
            <span class="mx-2" style="opacity:.3">·</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color:var(--text-dim);">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
